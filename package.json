{
  "name": "google-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbo",
    "dev:all": "bash ./start-database.sh && concurrently -c \"blue,green,magenta\" -n \"next,studio,ngrok\" \"pnpm dev\" \"pnpm run db:studio\" \"ngrok http 3000\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test-script": "tsx src/server/test.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.2",
    "@clerk/themes": "^2.4.57",
    "@corsair-dev/cli": "^0.1.19",
    "@corsair-dev/gmail": "^0.1.4",
    "@corsair-dev/googlecalendar": "^0.1.3",
    "@corsair-dev/mcp": "^0.1.22",
    "@openai/agents": "^0.11.6",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "corsair": "^0.1.76",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.41.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "^15.2.3",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "eslint-plugin-drizzle": "^0.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@11.6.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@clerk/shared"
    ]
  }
}